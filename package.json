{
  "name": "sofascore-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SofaScore ChatGPT App — an MCP (Apps SDK) server that answers football questions with rich interactive widgets, centered on the FIFA World Cup.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:widgets": "tsx scripts/build-widgets.ts",
    "build": "npm run build:widgets",
    "dev": "npm run build:widgets && tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "verify:wiring": "tsx scripts/smoke.ts",
    "verify:widgets": "tsx scripts/screenshots.ts",
    "verify": "npm run build:widgets && tsx scripts/smoke.ts && tsx scripts/screenshots.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "express": "^4.21.2",
    "undici": "^7.28.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
